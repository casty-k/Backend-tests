        {
          "name": "HAPPY-006 — Request Token (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('token');",
                  "});",
                  "",
                  "pm.test('Token is valid RS256 JWT', function() {",
                  "    const response = pm.response.json();",
                  "    const parts = response.token.split('.');",
                  "    pm.expect(parts.length).to.equal(3);",
                  "    pm.expect(parts[0]).to.equal('eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9' || true);",
                  "});",
                  "",
                  "pm.test('JWT payload contains required claims', function() {",
                  "    const response = pm.response.json();",
                  "    const parts = response.token.split('.');",
                  "    const payload = JSON.parse(atob(parts[1]));",
                  "    pm.expect(payload).to.have.property('sub');",
                  "    pm.expect(payload).to.have.property('roles');",
                  "    pm.expect(payload).to.have.property('context_id');",
                  "    pm.expect(payload).to.have.property('user_type');",
                  "    pm.expect(payload).to.have.property('exp');",
                  "});",
                  "",
                  "pm.test('JWT exp is 1 hour from now', function() {",
                  "    const response = pm.response.json();",
                  "    const parts = response.token.split('.');",
                  "    const payload = JSON.parse(atob(parts[1]));",
                  "    const now = Math.floor(Date.now() / 1000);",
                  "    const diff = payload.exp - payload.iat;",
                  "    pm.expect(diff).to.be.closeTo(3600, 10);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.environment.set('test_user_token', response.token);",
                  "const parts = response.token.split('.');",
                  "const payload = JSON.parse(atob(parts[1]));",
                  "pm.collectionVariables.set('test_jwt_jti', payload.jti);"
                ]
              }
            }
          ],
