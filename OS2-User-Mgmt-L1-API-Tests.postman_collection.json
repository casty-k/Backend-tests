  "item": [
    {
      "name": "Setup & Cleanup",
      "item": [
        {
          "name": "Setup — Get Admin Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('token');",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.environment.set('admin_token', response.token);",
                  "pm.collectionVariables.set('admin_jwt', response.token);",
                  "",
                  "pm.test('Extract JWT claims', function() {",
                  "    const parts = response.token.split('.');",
                  "    const payload = JSON.parse(atob(parts[1]));",
                  "    pm.expect(payload).to.have.property('sub');",
                  "    pm.expect(payload).to.have.property('roles');",
                  "    pm.expect(payload.roles).to.include('tech.admin.manager');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\":\"{{admin_phone}}\",\n    \"password\":\"{{admin_password}}\",\n    \"otp\":\"{{mocked_otp}}\",\n    \"context_id\":\"{{context_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{user_svc_base_url}}/api/v1/auth/token",
              "host": [
                "{{user_svc_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        }
      ]
    },
