            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\":\"+254746774941\",\n    \"password\":\"temp-pass-1234\",\n    \"otp\":\"{{mocked_otp}}\",\n    \"context_id\":\"{{context_id}}\"\n}",
