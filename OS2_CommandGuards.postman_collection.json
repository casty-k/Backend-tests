{
  "info": {
    "name": "OS2 Command Guards — CI/CD Smoke Gate",
    "_postman_id": "os2-command-guards-v1",
    "description": "GraphQL command-level authorization guard tests. All requests go through Apollo Router.\nCovers: RBAC-04, RBAC-09, RBAC-10, CON-04, CON-06, CON-09, AR-04, AR-05, FLT-03, FLT-05, FLT-07.\nRun via Newman in CI: newman run OS2_CommandGuards.postman_collection.json --env-var APOLLO_ROUTER_URL=$APOLLO_ROUTER_URL\nGate: Every PR (smoke suite) and full regression.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "APOLLO_ROUTER_URL", "value": "{{APOLLO_ROUTER_URL}}" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{JWT_ACTIVE_SESSION}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level pre-request: ensure APOLLO_ROUTER_URL is set",
          "if (!pm.environment.get('APOLLO_ROUTER_URL')) {",
          "  throw new Error('APOLLO_ROUTER_URL environment variable is not set');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "RBAC Guards",
      "item": [
        {
          "name": "[RBAC-04] Missing role — contract.activate returns 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP status is 200 (GraphQL envelope)', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('GraphQL errors array is present', function() {",
                  "  pm.expect(body).to.have.property('errors');",
                  "  pm.expect(body.errors).to.be.an('array').with.length.above(0);",
                  "});",
                  "pm.test('Error code is FORBIDDEN (403)', function() {",
                  "  const err = body.errors[0];",
                  "  pm.expect(err.extensions.code).to.eq('FORBIDDEN');",
                  "  pm.expect(err.extensions.http.status).to.eq(403);",
                  "});",
                  "pm.test('data.activateContract is null', function() {",
                  "  pm.expect(body.data.activateContract).to.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{JWT_ACQUISITION_ASSOCIATE}}" }
            ],
            "url": { "raw": "{{APOLLO_ROUTER_URL}}/graphql", "host": ["{{APOLLO_ROUTER_URL}}"], "path": ["graphql"] },
            "body": {
              "mode": "raw",
              "raw": "{ \"query\": \"mutation ActivateContract($contractId: ID!) { activateContract(contractId: $contractId) { id status } }\", \"variables\": { \"contractId\": \"QA-CONTRACT-GUARD-001\" } }"
            }
          }
        },
        {
          "name": "[RBAC-09] Human user cannot impersonate system.scheduler — billing run returns 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('HTTP status 200 (GraphQL envelope)', function() { pm.response.to.have.status(200); });",
                  "pm.test('FORBIDDEN error returned', function() {",
                  "  pm.expect(body.errors[0].extensions.code).to.eq('FORBIDDEN');",
                  "  pm.expect(body.errors[0].extensions.http.status).to.eq(403);",
                  "});",
                  "pm.test('data.runBillingCycle is null', function() {",
                  "  pm.expect(body.data.runBillingCycle).to.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{JWT_FINANCE_OPS_MANAGER}}" }
            ],
            "url": { "raw": "{{APOLLO_ROUTER_URL}}/graphql", "host": ["{{APOLLO_ROUTER_URL}}"], "path": ["graphql"] },
            "body": {
              "mode": "raw",
              "raw": "{ \"query\": \"mutation RunBillingCycle($cycleDate: String!) { runBillingCycle(cycleDate: $cycleDate) { cycleId status contractsProcessed } }\", \"variables\": { \"cycleDate\": \"2026-07-07\" } }"
            }
          }
        },
        {
          "name": "[RBAC-10] Customer role cannot query another customer's projection",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('HTTP status 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('customer data is null or FORBIDDEN', function() {",
                  "  const result = body.data && body.data.customer;",
                  "  const isForbidden = body.errors && body.errors[0].extensions.code === 'FORBIDDEN';",
                  "  pm.expect(result === null || isForbidden).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{JWT_CUSTOMER_PORTAL}}" }
            ],
            "url": { "raw": "{{APOLLO_ROUTER_URL}}/graphql", "host": ["{{APOLLO_ROUTER_URL}}"], "path": ["graphql"] },
            "body": {
              "mode": "raw",
              "raw": "{ \"query\": \"query GetCustomer($customerId: ID!) { customer(id: $customerId) { id fullName contractStatus outstandingBalance } }\", \"variables\": { \"customerId\": \"CUST-QA-OTHER-001\" } }"
            }
          }
        }
      ]
    },
    {
